<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<AnchorPane prefHeight="800.0" prefWidth="1300.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="hr.algebra.controller.AdminMainController">

    <!-- Navbar -->
    <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="1300.0"
          style="-fx-background-color: #1a1a2e;"
          AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- Logo -->
        <Label text="⌚ SmartWatch" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>

        <!-- Nav buttons -->
        <Button text="Smart Watches"
                onAction="#handleSmartWatches"
                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13px; -fx-cursor: hand;">
            <HBox.margin><Insets left="40.0"/></HBox.margin>
        </Button>

        <Button text="Brands"
                onAction="#handleBrands"
                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13px; -fx-cursor: hand;">
            <HBox.margin><Insets left="20.0"/></HBox.margin>
        </Button>

        <Button text="Categories"
                onAction="#handleCategories"
                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13px; -fx-cursor: hand;">
            <HBox.margin><Insets left="20.0"/></HBox.margin>
        </Button>

        <Button text="Users"
                onAction="#handleUsers"
                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13px; -fx-cursor: hand;">
            <HBox.margin><Insets left="20.0"/></HBox.margin>
        </Button>

        <!-- Admin badge + Logout (push to right) -->
        <HBox HBox.hgrow="ALWAYS"/>

        <Label fx:id="adminLabel"
               text="👤 Admin"
               style="-fx-text-fill: #a0aec0; -fx-font-size: 13px;"/>

        <Button text="Logout"
                onAction="#handleLogout"
                style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;">
            <HBox.margin><Insets left="20.0" right="20.0"/></HBox.margin>
        </Button>

        <padding><Insets left="30.0" right="10.0"/></padding>
    </HBox>

    <!-- Action toolbar — admin only -->
    <HBox prefHeight="45.0" prefWidth="1300.0" spacing="10"
          alignment="CENTER_LEFT"
          style="-fx-background-color: #16213e; -fx-border-color: #0f3460; -fx-border-width: 0 0 1 0;"
          AnchorPane.topAnchor="60" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <Button fx:id="btnAdd"
                text="＋ Add"
                onAction="#handleAdd"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 4;">
        </Button>

        <Button fx:id="btnEdit"
                text="✎ Edit"
                onAction="#handleEdit"
                style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 4;">
        </Button>

        <Button fx:id="btnDelete"
                text="✕ Delete"
                onAction="#handleDelete"
                style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 4;">
        </Button>

        <Button fx:id="btnExportXml"
                text="⬇ Export XML"
                onAction="#handleExportXml"
                style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 4;">
        </Button>

        <Label fx:id="statusLabel" text="" style="-fx-text-fill: #a0aec0; -fx-font-size: 12px;"/>

        <padding><Insets left="20.0"/></padding>
    </HBox>

    <!-- Content pane -->
    <StackPane fx:id="contentPane"
               style="-fx-background-color: #0f0f1a;"
               AnchorPane.topAnchor="105.0"
               AnchorPane.bottomAnchor="0.0"
               AnchorPane.leftAnchor="0.0"
               AnchorPane.rightAnchor="0.0"/>

</AnchorPane>
