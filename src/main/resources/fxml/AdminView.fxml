<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="800.0" prefWidth="1300.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="hr.algebra.controller.AdminViewController"
            stylesheets="@../css/menu.css">

    <!-- Navbar -->
    <HBox alignment="CENTER_LEFT" prefHeight="60.0"
          style="-fx-background-color: #1a1a2e;"
          AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <padding><Insets left="20" right="20"/></padding>

        <!-- Logo -->
        <Label text="⌚ SmartWatch"
               style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>

        <!-- Entity navigation -->
        <Button text="Smart Watches" onAction="#handleSmartWatches"
                style="-fx-background-color: transparent; -fx-text-fill: white;
                       -fx-font-size: 13px; -fx-cursor: hand;">
            <HBox.margin><Insets left="30"/></HBox.margin>
        </Button>

        <Button text="Brands" onAction="#handleBrands"
                style="-fx-background-color: transparent; -fx-text-fill: white;
                       -fx-font-size: 13px; -fx-cursor: hand;">
            <HBox.margin><Insets left="16"/></HBox.margin>
        </Button>

        <Button text="Categories" onAction="#handleCategories"
                style="-fx-background-color: transparent; -fx-text-fill: white;
                       -fx-font-size: 13px; -fx-cursor: hand;">
            <HBox.margin><Insets left="16"/></HBox.margin>
        </Button>

        <Button text="Health Functions" onAction="#handleHealthFunctions"
                style="-fx-background-color: transparent; -fx-text-fill: white;
                       -fx-font-size: 13px; -fx-cursor: hand;">
            <HBox.margin><Insets left="16"/></HBox.margin>
        </Button>

        <Button text="Operating Systems" onAction="#handleOperatingSystems"
                style="-fx-background-color: transparent; -fx-text-fill: white;
                       -fx-font-size: 13px; -fx-cursor: hand;">
            <HBox.margin><Insets left="16"/></HBox.margin>
        </Button>

        <Button text="Users" onAction="#handleUsers"
                style="-fx-background-color: transparent; -fx-text-fill: white;
                       -fx-font-size: 13px; -fx-cursor: hand;">
            <HBox.margin><Insets left="16"/></HBox.margin>
        </Button>

        <!-- Push logout right -->
        <HBox HBox.hgrow="ALWAYS"/>

        <Label text="👤 Admin" style="-fx-text-fill: #a0aec0; -fx-font-size: 13px;"/>

        <Button text="Logout" onAction="#handleLogout"
                style="-fx-background-color: #c0392b; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;
                       -fx-padding: 6 14 6 14;">
            <HBox.margin><Insets left="16"/></HBox.margin>
        </Button>
    </HBox>

    <!--Action toolbar-->
    <HBox prefHeight="45.0" spacing="10" alignment="CENTER_LEFT"
          style="-fx-background-color: #16213e; -fx-border-color: #0f3460;
                 -fx-border-width: 0 0 1 0;"
          AnchorPane.topAnchor="60" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <padding><Insets left="20"/></padding>

        <Button text="＋ Add"        onAction="#handleAdd"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 4;
                       -fx-padding: 6 14 6 14;"/>

        <Button text="✎ Edit"       onAction="#handleEdit"
                style="-fx-background-color: #2980b9; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 4;
                       -fx-padding: 6 14 6 14;"/>

        <Button text="✕ Delete"     onAction="#handleDelete"
                style="-fx-background-color: #c0392b; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 4;
                       -fx-padding: 6 14 6 14;"/>

        <Button text="⬇ Export XML" onAction="#handleExportXml"
                style="-fx-background-color: #8e44ad; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 4;
                       -fx-padding: 6 14 6 14;"/>

        <Pane prefWidth="10"/>

        <ToggleButton fx:id="toggleViewButton"
                      text="📋 Table View"
                      onAction="#handleToggleView"
                      style="-fx-background-color: #2d2d44; -fx-text-fill: #a0aec0;
                             -fx-background-radius: 4; -fx-cursor: hand;
                             -fx-padding: 6 14 6 14;"/>

        <Pane prefWidth="10"/>

        <Button text="🗑 Drop DB"   onAction="#handleDropDb"
                style="-fx-background-color: #7f0000; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 4;
                       -fx-padding: 6 14 6 14;"/>

        <Button text="↺ Reset DB"  onAction="#handleResetDb"
                style="-fx-background-color: #e67e22; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 4;
                       -fx-padding: 6 14 6 14;"/>

        <Label fx:id="statusLabel"
               style="-fx-text-fill: #a0aec0; -fx-font-size: 12px; -fx-padding: 0 0 0 10;"/>
    </HBox>

    <!--Content pane-->
    <StackPane fx:id="contentPane"
               style="-fx-background-color: #0f0f1a;"
               AnchorPane.topAnchor="105.0"
               AnchorPane.bottomAnchor="0.0"
               AnchorPane.leftAnchor="0.0"
               AnchorPane.rightAnchor="0.0"/>

</AnchorPane>
