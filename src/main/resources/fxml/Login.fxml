<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>


<GridPane alignment="center" hgap="10" style="-fx-background-color: #f4f4f4;" vgap="12" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
    <padding><Insets bottom="30" left="40" right="40" top="30" /></padding>

    <Label style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #333;" text="SmartWatch App" GridPane.columnSpan="2" GridPane.halignment="CENTER" GridPane.rowIndex="0" />

    <Label text="Username:" GridPane.rowIndex="1" />
    <TextField fx:id="usernameField" prefWidth="180" promptText="JohnDoe..." GridPane.columnIndex="1" GridPane.rowIndex="1" />

    <Label text="Password:" GridPane.rowIndex="2" />
    <PasswordField fx:id="passwordField" promptText="Password..." GridPane.columnIndex="1" GridPane.rowIndex="2" />

    <Button maxWidth="Infinity" onAction="#handleLogin" prefHeight="25.0" prefWidth="50.0" style="-fx-background-color: #c30e60; -fx-text-fill: white; -fx-font-weight: bold;" text="Login" GridPane.columnIndex="1" GridPane.rowIndex="3" />

    <Button maxWidth="Infinity" onAction="#loadRegistration" prefHeight="25.0" prefWidth="50.0" style="-fx-background-color: #0b618c; -fx-text-fill: white; -fx-font-weight: bold;" text="Registration" GridPane.columnIndex="1" GridPane.rowIndex="4" />

</GridPane>
