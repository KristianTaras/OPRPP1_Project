<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      spacing="0"
      style="-fx-background-color: #0f0f1a;">

    <TableView fx:id="watchTable"
               VBox.vgrow="ALWAYS"
               style="-fx-background-color: #0f0f1a;
                      -fx-table-cell-border-color: #2d2d44;
                      -fx-control-inner-background: #0f0f1a;
                      -fx-control-inner-background-alt: #161628;">

        <columns>
            <TableColumn fx:id="colName"       text="Name"         prefWidth="200"/>
            <TableColumn fx:id="colBrand"      text="Brand"        prefWidth="110"/>
            <TableColumn fx:id="colYear"       text="Year"         prefWidth="65"/>
            <TableColumn fx:id="colPrice"      text="Price (€)"    prefWidth="90"/>
            <TableColumn fx:id="colScreenSize" text="Screen (in)"  prefWidth="90"/>
            <TableColumn fx:id="colBattery"    text="Battery (h)"  prefWidth="90"/>
            <TableColumn fx:id="colIpRating"   text="IP Rating"    prefWidth="80"/>
            <TableColumn fx:id="colOS"         text="OS"           prefWidth="120"/>
            <TableColumn fx:id="colCategory"   text="Category"     prefWidth="100"/>
            <TableColumn fx:id="colHealth"     text="Health Fn."   prefWidth="220"/>
        </columns>

        <placeholder>
            <Label text="No smart watches found."
                   style="-fx-text-fill: #555; -fx-font-size: 13px;"/>
        </placeholder>

    </TableView>

</VBox>