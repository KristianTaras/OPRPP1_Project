<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      spacing="0"
      prefWidth="900" prefHeight="620"
      style="-fx-background-color: #111;">

    <!--Left: input field-->
    <ScrollPane fitToWidth="true" prefWidth="420"
                style="-fx-background: #111; -fx-background-color: #111;">
        <VBox spacing="12">
            <padding><Insets top="24" right="20" bottom="24" left="24"/></padding>

            <Label text="ADD SMART WATCH"
                   style="-fx-text-fill: #e94560; -fx-font-size: 14px;
                          -fx-font-weight: bold; -fx-padding: 0 0 8 0;"/>

            <!-- Name -->
            <VBox spacing="4">
                <Label text="Name" style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
                <TextField fx:id="nameField" promptText="Apple Watch Ultra 2"
                           style="-fx-background-color: #1a1a1a; -fx-text-fill: #eee;
                                  -fx-border-color: #333; -fx-border-radius: 6;
                                  -fx-background-radius: 6; -fx-padding: 8 12 8 12;"/>
            </VBox>

            <!-- Year + Screen Size -->
            <HBox spacing="12">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Year" style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
                    <TextField fx:id="yearField" promptText="2024"
                               style="-fx-background-color: #1a1a1a; -fx-text-fill: #eee;
                                      -fx-border-color: #333; -fx-border-radius: 6;
                                      -fx-background-radius: 6; -fx-padding: 8 12 8 12;"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Screen Size (in)" style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
                    <TextField fx:id="screenSizeField" promptText="1.92"
                               style="-fx-background-color: #1a1a1a; -fx-text-fill: #eee;
                                      -fx-border-color: #333; -fx-border-radius: 6;
                                      -fx-background-radius: 6; -fx-padding: 8 12 8 12;"/>
                </VBox>
            </HBox>

            <!-- Battery + IP Rating -->
            <HBox spacing="12">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Battery Life (h)" style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
                    <TextField fx:id="batteryField" promptText="60"
                               style="-fx-background-color: #1a1a1a; -fx-text-fill: #eee;
                                      -fx-border-color: #333; -fx-border-radius: 6;
                                      -fx-background-radius: 6; -fx-padding: 8 12 8 12;"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="IP Rating" style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
                    <TextField fx:id="ipRatingField" promptText="IP68"
                               style="-fx-background-color: #1a1a1a; -fx-text-fill: #eee;
                                      -fx-border-color: #333; -fx-border-radius: 6;
                                      -fx-background-radius: 6; -fx-padding: 8 12 8 12;"/>
                </VBox>
            </HBox>

            <!-- Price -->
            <VBox spacing="4">
                <Label text="Price (€)" style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
                <TextField fx:id="priceField" promptText="799.99"
                           style="-fx-background-color: #1a1a1a; -fx-text-fill: #eee;
                                  -fx-border-color: #333; -fx-border-radius: 6;
                                  -fx-background-radius: 6; -fx-padding: 8 12 8 12;"/>
            </VBox>

            <!-- Image Path -->
            <VBox spacing="4">
                <Label text="Image Path" style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
                <HBox spacing="8">
                    <TextField fx:id="imagePathField" promptText="/images/watch.png"
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color: #1a1a1a; -fx-text-fill: #eee;
                                      -fx-border-color: #333; -fx-border-radius: 6;
                                      -fx-background-radius: 6; -fx-padding: 8 12 8 12;"/>
                    <Button text="Browse" onAction="#handleBrowseImage"
                            style="-fx-background-color: #333; -fx-text-fill: #aaa;
                                   -fx-background-radius: 6; -fx-cursor: hand;
                                   -fx-padding: 8 12 8 12;"/>
                    <Button text="🗑" onAction="#handleDeleteImage"
                            style="-fx-background-color: #7f0000; -fx-text-fill: white;
                   -fx-background-radius: 6; -fx-cursor: hand;
                   -fx-padding: 8 12 8 12;"/>

                </HBox>
            </VBox>

            <!-- Error label -->
            <Label fx:id="errorLabel" text="" wrapText="true"
                   style="-fx-text-fill: #e94560; -fx-font-size: 11px;"
                   visible="false" managed="false"/>

            <!-- Buttons -->
            <HBox spacing="10">
                <VBox.margin><Insets top="10"/></VBox.margin>
                <Button text="Save" onAction="#handleSave"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 6;
                               -fx-cursor: hand; -fx-padding: 10 0 10 0;"/>
                <Button text="Cancel" onAction="#handleCancel"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"
                        style="-fx-background-color: #333; -fx-text-fill: #aaa;
                               -fx-background-radius: 6; -fx-cursor: hand;
                               -fx-padding: 10 0 10 0;"/>
            </HBox>
        </VBox>
    </ScrollPane>

    <!-- Vertical divider -->
    <Pane prefWidth="1" style="-fx-background-color: #222;"/>

    <!--Right - drag and drop zone-->
    <ScrollPane fitToWidth="true" HBox.hgrow="ALWAYS"
                style="-fx-background: #0d0d0d; -fx-background-color: #0d0d0d;">
        <VBox spacing="16">
            <padding><Insets top="24" right="24" bottom="24" left="20"/></padding>

            <Label text="DRAG ENTITIES HERE"
                   style="-fx-text-fill: #555; -fx-font-size: 11px; -fx-font-weight: bold;"/>

            <!-- Brand drop zone -->
            <VBox spacing="6">
                <Label text="Brand" style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
                <StackPane fx:id="brandDropZone" prefHeight="60"
                           style="-fx-background-color: #1a1a1a;
                                  -fx-border-color: #333; -fx-border-width: 2;
                                  -fx-border-style: dashed; -fx-border-radius: 8;
                                  -fx-background-radius: 8;">
                    <Label fx:id="brandDropLabel" text="Drop Brand here"
                           style="-fx-text-fill: #444; -fx-font-size: 12px;"/>
                </StackPane>
            </VBox>

            <!-- Category drop zone -->
            <VBox spacing="6">
                <Label text="Category" style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
                <StackPane fx:id="categoryDropZone" prefHeight="60"
                           style="-fx-background-color: #1a1a1a;
                                  -fx-border-color: #333; -fx-border-width: 2;
                                  -fx-border-style: dashed; -fx-border-radius: 8;
                                  -fx-background-radius: 8;">
                    <Label fx:id="categoryDropLabel" text="Drop Category here"
                           style="-fx-text-fill: #444; -fx-font-size: 12px;"/>
                </StackPane>
            </VBox>

            <!-- Operating System drop zone -->
            <VBox spacing="6">
                <Label text="Operating System" style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
                <StackPane fx:id="osDropZone" prefHeight="60"
                           style="-fx-background-color: #1a1a1a;
                                  -fx-border-color: #333; -fx-border-width: 2;
                                  -fx-border-style: dashed; -fx-border-radius: 8;
                                  -fx-background-radius: 8;">
                    <Label fx:id="osDropLabel" text="Drop Operating System here"
                           style="-fx-text-fill: #444; -fx-font-size: 12px;"/>
                </StackPane>
            </VBox>

            <!-- Health Functions drop zone — multiple -->
            <VBox spacing="6">
                <Label text="Health Functions (multiple)"
                       style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
                <VBox fx:id="healthDropZone" spacing="6" prefHeight="80"
                      style="-fx-background-color: #1a1a1a;
                             -fx-border-color: #333; -fx-border-width: 2;
                             -fx-border-style: dashed; -fx-border-radius: 8;
                             -fx-background-radius: 8; -fx-padding: 10;">
                    <Label fx:id="healthDropLabel" text="Drop Health Functions here"
                           style="-fx-text-fill: #444; -fx-font-size: 12px;"/>
                </VBox>
            </VBox>

            <!-- Divider -->
            <Pane prefHeight="1" style="-fx-background-color: #222;"/>

            <!-- Available entities to drag FROM -->
            <Label text="AVAILABLE ENTITIES"
                   style="-fx-text-fill: #555; -fx-font-size: 11px; -fx-font-weight: bold;"/>

            <!-- Brands list -->
            <VBox spacing="6">
                <Label text="Brands" style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
                <FlowPane fx:id="brandsPane" hgap="8" vgap="8"
                          style="-fx-background-color: #161616;
                                 -fx-background-radius: 8; -fx-padding: 10;"/>
            </VBox>

            <!-- Categories list -->
            <VBox spacing="6">
                <Label text="Categories" style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
                <FlowPane fx:id="categoriesPane" hgap="8" vgap="8"
                          style="-fx-background-color: #161616;
                                 -fx-background-radius: 8; -fx-padding: 10;"/>
            </VBox>

            <!-- Operating Systems list -->
            <VBox spacing="6">
                <Label text="Operating Systems" style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
                <FlowPane fx:id="osPane" hgap="8" vgap="8"
                          style="-fx-background-color: #161616;
                                 -fx-background-radius: 8; -fx-padding: 10;"/>
            </VBox>

            <!-- Health Functions list -->
            <VBox spacing="6">
                <Label text="Health Functions" style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
                <FlowPane fx:id="healthPane" hgap="8" vgap="8"
                          style="-fx-background-color: #161616;
                                 -fx-background-radius: 8; -fx-padding: 10;"/>
            </VBox>

        </VBox>
    </ScrollPane>
</HBox>
