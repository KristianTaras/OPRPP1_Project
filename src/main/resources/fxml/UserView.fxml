<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Menu?>

<VBox prefHeight="800.0" prefWidth="1300.0" style="-fx-background-color: #0f0f1a;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="hr.algebra.controller.UserViewController"
      stylesheets="@../css/menu.css">

    <!-- Navbar -->
    <HBox alignment="CENTER_LEFT" prefHeight="45"
          style="-fx-background-color: #1a1a2e;">
        <padding><Insets left="20" right="20" xmlns="http://javafx.com/javafx/21"/></padding>

        <!-- Left — Logo + Views -->
        <MenuBar HBox.hgrow="NEVER"
                 style="-fx-background-color: transparent; -fx-padding: 0;">
            <Menu text="⌚ SmartWatch"/>
            <Menu text="Views">
                <MenuItem text="🖥 Smart Watches" onAction="#handleSmartWatches" styleClass="views-item"/>
                <MenuItem text="💊 Compare Health Functions" onAction="#handleCompare" styleClass="views-item"/>
                <MenuItem text="ℹ About" onAction="#handleAbout" styleClass="views-item"/>
            </Menu>
        </MenuBar>

        <!-- Spacer  -->
        <Pane HBox.hgrow="ALWAYS"/>

        <!-- Right — User label + Logout -->
        <Label text="👤 User"
               style="-fx-text-fill: white; -fx-font-size: 13px;"/>

        <Button text="Logout" onAction="#handleLogout"
                style="-fx-background-color: #c0392b; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-cursor: hand;
                       -fx-background-radius: 5; -fx-padding: 6 14 6 14;">
            <HBox.margin>
                <Insets left="16" xmlns="http://javafx.com/javafx/21"/>
            </HBox.margin>
        </Button>

    </HBox>

    <!-- Content pane -->
    <StackPane fx:id="contentPane"
               style="-fx-background-color: #0f0f1a;"
               VBox.vgrow="ALWAYS"/>

</VBox>