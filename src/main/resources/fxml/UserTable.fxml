<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      spacing="0" style="-fx-background-color: #0f0f1a;">

    <TableView fx:id="userTable" VBox.vgrow="ALWAYS"
               style="-fx-background-color: #0f0f1a; -fx-table-cell-border-color: #2d2d44;
                      -fx-control-inner-background: #0f0f1a;
                      -fx-control-inner-background-alt: #161628;">
        <columns>
            <TableColumn fx:id="colId"          text="ID"           prefWidth="60"/>
            <TableColumn fx:id="colFirstName"   text="First Name"   prefWidth="130"/>
            <TableColumn fx:id="colLastName"    text="Last Name"    prefWidth="130"/>
            <TableColumn fx:id="colUsername"    text="Username"     prefWidth="130"/>
            <TableColumn fx:id="colEmail"       text="Email"        prefWidth="200"/>
            <TableColumn fx:id="colPhone"       text="Phone"        prefWidth="120"/>
            <TableColumn fx:id="colRole"        text="Role"         prefWidth="80"/>
        </columns>
        <placeholder>
            <Label text="No users found." style="-fx-text-fill: #555;"/>
        </placeholder>
    </TableView>
</VBox>
